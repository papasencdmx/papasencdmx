# ─────────────────────────────────────────────────────────────
# Papás en CDMX — environment template
# Copy this file to ".env.local" and fill in the real values.
# NEVER commit .env.local (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Supabase (create a NEW Supabase project for CDMX)
NEXT_PUBLIC_SUPABASE_URL=https://your-cdmx-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# City config
NEXT_PUBLIC_CITY_SLUG=cdmx
NEXT_PUBLIC_SITE_DOMAIN=papasencdmx.com
NEXT_PUBLIC_NEWSLETTER_DOMAIN=newsletter.papasencdmx.com
NEXT_PUBLIC_SITE_URL=https://papasencdmx.com

# Support contact (Mexican format)
NEXT_PUBLIC_SUPPORT_PHONE_E164=+525555555555
NEXT_PUBLIC_SUPPORT_EMAIL=hola@papasencdmx.com

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Email notifications (Resend)
RESEND_API_KEY=
RESEND_FROM=Papás en CDMX <hola@papasencdmx.com>

# Newsletter (Beehiiv) — optional
BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=

# Analytics
NEXT_PUBLIC_GA_ID=

# Payments — Stripe (supports MXN; the payment provider for Mexico)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin login
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SECRET=
